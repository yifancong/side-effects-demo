{
  "include": ["src"],
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["DOM", "ESNext"],
    "allowJs": true,
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "moduleResolution": "Bundler",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "module": "ESNext"
  }
}
